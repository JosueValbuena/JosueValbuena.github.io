---
 
<section id="proyectos" class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
 
    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">
        Proyectos <span class="bg-linear-to-r from-primary to-purple-500 bg-clip-text text-transparent">destacados</span>
      </h2>
      <p class="text-gray-400 max-w-xl mx-auto">
        Trabajos reales para clientes y proyectos personales
      </p>
    </div>
 
    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map((project) => (
        <div
          class={`rounded-xl border border-neutral-800 overflow-hidden group transition-all hover:border-primary/40 ${
            project.featured ? "md:col-span-2" : ""
          }`}
        >
          <div class={project.featured ? "md:flex" : ""}>
 
            <!-- Image -->
            <div class={`overflow-hidden ${project.featured ? "md:w-3/5" : "w-full"}`}>
              <Image
                src={projectImages[`../assets/projects/${project.image}`].default}
                alt={project.title}
                widths={[400, 800]}
                sizes="(max-width: 768px) 100vw, 50vw"
                class="w-full h-48 md:h-64 object-cover object-top transition-transform duration-500 group-hover:scale-105"
              />
            </div>
 
            <!-- Content -->
            <div class={`p-6 ${project.featured ? "md:w-2/5 flex flex-col justify-center" : ""}`}>
 
              <!-- Bandera + año, alineados a la derecha, entre la imagen y el título -->
              <div class="flex items-center justify-end gap-2">
                <span
                  class="w-5 h-3.5 rounded-sm overflow-hidden border border-neutral-700 shrink-0"
                  title={countryNames[project.country]}
                  aria-label={countryNames[project.country]}
                  set:html={flags[project.country]}
                />
                <span class="text-xs text-gray-400 border border-neutral-700 rounded-full px-2.5 py-0.5">
                  {project.year}
                </span>
              </div>
 
              <h3 class="text-xl font-semibold text-white mb-2">
                {project.title}
              </h3>
 
              <p class="text-sm text-gray-400 mb-4 leading-relaxed">
                {project.description}
              </p>
 
              <!-- Tech tags -->
              <div class="flex flex-wrap gap-2 mb-4">
                {project.tech.map((t) => (
                  <span class="text-xs bg-neutral-800 text-gray-300 px-2.5 py-1 rounded-md">
                    {t}
                  </span>
                ))}
              </div>
 
              <!-- Links -->
              <div class="flex gap-4 text-sm">
                {project.demo && (
                  <a
                    href={project.demo}
                    target="_blank"
                    aria-label={`Ver demo del proyecto ${project.title}`}
                    rel="noopener noreferrer"
                    class="text-primary hover:underline"
                  >
                    Demo →
                  </a>
                )}
                {project.code && (
                  <a
                    href={project.code}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Ver código del proyecto ${project.title}`}
                    class="text-gray-400 hover:text-white transition-colors"
                  >
                    Código →
                  </a>
                )}
              </div>
 
            </div>
          </div>
        </div>
      ))}
    </div>
 
  </div>
</section>